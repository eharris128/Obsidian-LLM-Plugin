		"eslint": "10.4.1",
		"globals": "17.6.0",
		"obsidian": "1.13.0",
		"tslib": "2.8.1",
		"typescript": "6.0.3",
		"typescript-eslint": "8.60.1"
	},
	"dependencies": {
		"@anthropic-ai/claude-agent-sdk": "0.3.165",
