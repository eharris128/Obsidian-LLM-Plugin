{
	"compilerOptions": {
		"module": "ESNext",
		"target": "ES2022",
		"moduleResolution": "bundler",
		"lib": ["ES2022", "DOM"],
		"strict": true,
		"esModuleInterop": true,
		"resolveJsonModule": true,
		"skipLibCheck": true,
		"noEmit": true,
		"types": ["node", "mocha", "@wdio/globals/types", "@wdio/mocha-framework", "wdio-obsidian-service"]
	},
	"include": ["specs/**/*.ts", "../wdio.conf.mts"]
}
